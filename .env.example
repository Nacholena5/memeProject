APP_ENV=dev
APP_NAME=meme-research
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_FILE=meme_research.log
NETWORK=solana
SCAN_INTERVAL_SECONDS=300

SCANNER_AUTO_ENABLED=true
SCANNER_INTERVAL_MINUTES=30
SCANNER_DISCOVERY_LIMIT=120
SCANNER_MIN_TOKEN_AGE_MINUTES=30
SCANNER_MAX_TOKEN_AGE_HOURS=72
SCANNER_MIN_LIQUIDITY_USD=80000
SCANNER_MIN_VOLUME_1H_USD=40000
SCANNER_MIN_TRANSACTIONS_1H=120
SCANNER_MIN_BUYS_SELLS_RATIO=1.1
SCANNER_MAX_BUYS_SELLS_RATIO=2.8
SCANNER_MIN_MARKET_CAP_USD=300000
SCANNER_MAX_MARKET_CAP_USD=25000000
SCANNER_MIN_VOLUME_ACCELERATION=0.12
SCANNER_MAX_PAID_ATTENTION_SCORE=2
SCANNER_MAX_RISK_FOR_LONG=35
SCANNER_MIN_SCORE_FOR_LONG=68
SCANNER_MIN_CONFIDENCE_FOR_LONG=0.72
SCANNER_MAX_RISK_FOR_SHORT=32
SCANNER_MIN_SCORE_FOR_SHORT=70
SCANNER_MIN_CONFIDENCE_FOR_SHORT=0.74
SCANNER_MIN_DATA_QUALITY_SCORE=65
SCANNER_MAX_VERTICAL_PUMP_PCT=55

# Local-first default DB (recommended)
DATABASE_URL=sqlite:///./meme_research.db

# Optional (only if you really want PostgreSQL locally)
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/meme_research

REDIS_URL=redis://localhost:6379/0
DEXSCREENER_BASE_URL=https://api.dexscreener.com
BIRDEYE_BASE_URL=https://public-api.birdeye.so
BIRDEYE_API_KEY=
GOPLUS_BASE_URL=https://api.gopluslabs.io
HONEYPOT_BASE_URL=https://api.honeypot.is
HELIUS_RPC_URL=https://mainnet.helius-rpc.com
HELIUS_API_KEY=
COINGLASS_BASE_URL=https://open-api.coinglass.com
COINGLASS_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
MIN_LIQUIDITY_USD=50000
MIN_VOLUME_1H_USD=20000
MAX_SPREAD_BPS=200
MAX_TOP10_HOLDERS_PCT=70
MIN_LP_LOCKED_PCT=60
LONG_THRESHOLD=70
SHORT_THRESHOLD=72
MIN_CONFIDENCE=0.65
TOP_K=10
ALERT_DEDUPE_MINUTES=30
OUTCOME_HORIZONS=1h,4h,24h
